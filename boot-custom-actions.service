[Unit]
Description=Boot custom actions
After=network.target
Before=display-manager.service

[Service]
Type=oneshot
User=playnix
Group=playnix
ExecStart=/usr/local/bin/boot-custom-actions.sh
RemainAfterExit=yes
TimeoutStartSec=600
TTYPath=/dev/tty1
StandardInput=tty
StandardOutput=tty
StandardError=tty

[Install]
WantedBy=multi-user.target